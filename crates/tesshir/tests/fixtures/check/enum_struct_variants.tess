enum Message {
    Quit,
    Move { x: i32, y: i32 },
    Write(i32, bool),
}

fn handle(message: Message) -> i32 {
    match message {
        Message::Quit => 0,
        Message::Move { x, y } => x + y,
        Message::Write(n, flag) => if flag { n } else { 0 },
    }
}

fn make_move() -> Message {
    Message::Move { x: 1, y: 2 }
}
