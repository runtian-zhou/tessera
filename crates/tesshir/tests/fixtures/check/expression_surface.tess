fn inc(x: i32) -> i32 {
    x + 1
}

fn ops(a: i32, b: i32, arr: [i32; 4], flag: bool) -> i32 {
    let z: i32 = 0;
    z = inc(arr[0]);
    let arithmetic = -a + b * 2 / 1 % 3;
    let bits = ((a & b) | (a ^ b)) << 1 >> 1;
    let cmp = (a == b) || (a != b) || (a < b) || (a <= b) || (a > b) || (a >= b);
    let ok = flag && !false || cmp;
    if ok {
        bits + arithmetic + z
    } else {
        return a;
    }
}

fn unit_return() {
    return;
}
